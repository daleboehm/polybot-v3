# Polybot V3 Environment Configuration
# Copy to .env and fill in real values. NEVER commit .env.
#
# The engine loads these at process startup; changes require systemctl restart.

# ============================================================
# Engine mode — BOTH must be 'true' to enable real Polygon trading
# ============================================================
POLYBOT_LIVE_MODE=false
POLYBOT_LIVE_CONFIRM=false

# ============================================================
# Dashboard auth
# ============================================================
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=changeme

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=info

# ============================================================
# Paths (dashboard engine reads CONFIG_PATH + ENTITIES_PATH)
# ============================================================
DATABASE_PATH=./data/polybot.db
CONFIG_PATH=./config/default.yaml
ENTITIES_PATH=./config/entities.yaml

# ============================================================
# Strategy feature flags
# ============================================================
# LIFECYCLE_EDGE_ONLY=true forces longshot and favorites strategies
# to only enter markets in the first 6h of lifetime OR last 15% before expiry
# (filters out ~80-90% of markets). Disabled by default as it starves volume.
# 2026-04-23: confirmed disabling is correct for R&D paper money-maker mission.
LIFECYCLE_EDGE_ONLY=false

# Whale strategies
WHALE_COPY_ENABLED=true
WHALE_FADE_ENABLED=true
WHALE_FADE_SIZE_THRESHOLD=10000

# Maker rebate sports/esports strategy (post-only)
MAKER_REBATE_ENABLED=false

# ============================================================
# Required API keys (never commit real values)
# ============================================================

# Anthropic Console API for llm-news-scout (Haiku class)
# Console.anthropic.com billing — SEPARATE from Claude.ai Max subscription
ANTHROPIC_API_KEY=sk-ant-...

# FRED (Federal Reserve Economic Data) for macro_forecast strategy. Free.
FRED_API_KEY=

# Odds API (via parlay-api.com/v1 drop-in replacement). ~$20/mo for paid tier.
ODDS_API_KEY=

# Dune Analytics for whale PnL overlay scout
DUNE_API_KEY=

# Goldsky subgraph token for Polymarket positions/pnl subgraphs
GOLDSKY_TOKEN=

# Polygon RPC (Alchemy, Ankr, or self-hosted)
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY_HERE
