# Polybot V2 Environment Configuration
# Copy to .env and fill in values

# Engine mode — BOTH must be set to "live" to enable real trading
POLYBOT_LIVE_MODE=false
POLYBOT_LIVE_CONFIRM=false

# Dashboard auth
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=changeme

# Logging
LOG_LEVEL=info

# Database path (default: ./data/polybot.db)
DATABASE_PATH=./data/polybot.db

# Config path (default: ./config/default.yaml)
CONFIG_PATH=./config/default.yaml
ENTITIES_PATH=./config/entities.yaml
